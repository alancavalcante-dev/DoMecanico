# Copie este arquivo para .env e preencha os valores antes de subir para produção

# ─── Django ───────────────────────────────────────────────────────────────────
# Gere uma chave segura com: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=sua-secret-key-longa-e-aleatoria-aqui

DEBUG=False

# Hosts separados por vírgula (sem https://)
ALLOWED_HOSTS=api.seudominio.com.br,seudominio.com.br

# ─── Banco de dados ───────────────────────────────────────────────────────────
# Formato: postgres://usuario:senha@host:porta/banco
# Em produção com Docker, o host é "db" (nome do serviço no docker-compose)
DATABASE_URL=postgres://domecanico:SENHA_FORTE@db:5432/domecanico
DB_PASSWORD=SENHA_FORTE

# ─── Cache / Redis ────────────────────────────────────────────────────────────
# Formato: redis://:senha@host:porta/0  (sem senha: redis://host:porta/0)
REDIS_URL=redis://localhost:6379/0

# ─── CORS ─────────────────────────────────────────────────────────────────────
# URL do frontend em produção (sem barra final)
CORS_ALLOWED_ORIGINS=https://app.seudominio.com.br

# ─── Cloudflare R2 (mídia — logos, fotos de veículos) ────────────────────────
R2_ACCESS_KEY_ID=seu-access-key-id
R2_SECRET_ACCESS_KEY=seu-secret-access-key
R2_BUCKET_NAME=domecanico-media
R2_ENDPOINT_URL=https://SEU_ACCOUNT_ID.r2.cloudflarestorage.com
# R2_PUBLIC_URL=pub.seudominio.com.br  # opcional: domínio público do bucket

# ─── WhatsApp / Evolution API ─────────────────────────────────────────────────
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=sua-api-key-evolution
